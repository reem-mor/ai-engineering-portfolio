# Copy this file to .env in the same directory (frontend/) if you need a custom API URL.
# Never commit .env — it is listed in .gitignore.
#
# OpenAI API keys and model names belong in backend/.env only.
# The React app talks to FastAPI; the backend calls OpenAI.

# Dev default (backend on port 8000): omit .env and use the built-in default in src/config/env.ts
# Docker Compose: the image uses VITE_API_BASE_URL=/api and nginx proxies /api to the backend

VITE_API_BASE_URL=http://localhost:8000/api
