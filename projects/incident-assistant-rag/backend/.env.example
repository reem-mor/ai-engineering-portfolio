# Copy this file to .env in the same directory (backend/) and fill in real values.
# Never commit .env — it is listed in .gitignore.
#
# SECURITY: OpenAI keys and model names belong HERE ONLY.
# The React frontend never receives API keys — it calls FastAPI; the backend calls OpenAI.
# See frontend/.env.example for VITE_API_BASE_URL only.

APP_NAME=IncidentIQ RAG API
APP_VERSION=0.1.0
ENVIRONMENT=local

# OpenAI (required for live embeddings and chat)
OPENAI_API_KEY=sk-your-openai-api-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
ANSWER_MODEL=gpt-4o-mini

# Optional Supabase history (run backend/docs/supabase_schema.sql first)
DATABASE_ENABLED=false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional advanced tunables (defaults in app/core/config.py — uncomment to override)
# RETRIEVAL_SCORE_THRESHOLD=0.25
# CHUNK_SIZE=700
# CHUNK_OVERLAP=120
# TOP_K_DEFAULT=5
