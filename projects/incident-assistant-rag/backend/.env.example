# Copy this file to .env in the same directory (backend/) and fill in real values.
# Never commit .env — it is listed in .gitignore.

APP_NAME=IncidentIQ RAG API
APP_VERSION=0.1.0
ENVIRONMENT=local

# OpenAI (backend only — never put this in the frontend)
OPENAI_API_KEY=sk-your-openai-api-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
ANSWER_MODEL=gpt-4o-mini

# Optional Supabase history (run backend/docs/supabase_schema.sql first)
DATABASE_ENABLED=false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
