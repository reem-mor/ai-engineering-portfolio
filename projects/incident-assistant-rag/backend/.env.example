# IncidentIQ backend — copy to .env and fill in real values. Never commit .env.
# All model calls flow through the backend; the frontend holds no secrets.

# Required: OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here

# Models (defaults shown — override if needed)
ANSWER_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Environment label
ENVIRONMENT=local

# Optional: Supabase persistence. Set DATABASE_ENABLED=true and fill the two values,
# then apply database/schema.sql first.
DATABASE_ENABLED=false
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
