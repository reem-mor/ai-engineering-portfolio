            },
            {
                "type": "PASSWORD",
                "action": "BLOCK",
                "inputAction": "BLOCK",
                "outputAction": "ANONYMIZE",
                "inputEnabled": true,
                "outputEnabled": true
            }
        ],
        "regexes": [
            {
                "name": "aws_access_key_id",
                "description": "Blocks AWS access key IDs.",
                "pattern": "AKIA[0-9A-Z]{16}",
                "action": "BLOCK",
                "inputAction": "BLOCK",
                "outputAction": "BLOCK",
                "inputEnabled": true,
                "outputEnabled": true
            },
            {
                "name": "secret_assignment",
                "description": "Blocks common secret values in key value format.",
                "pattern": "(?i)(aws_secret_access_key|secret_key|api_key|password|token)\\s*=\\s*[\"']?[A-Za-z0-9_\\-\\/+=]{12,}[\"']?",
                "action": "BLOCK",
                "inputAction": "BLOCK",
                "outputAction": "ANONYMIZE",
                "inputEnabled": true,
                "outputEnabled": true
            },
            {
                "name": "private_key_header",
                "description": "Blocks private key material.",
                "pattern": "-----BEGIN [A-Z ]*PRIVATE KEY-----",
                "action": "BLOCK",
                "inputAction": "BLOCK",
                "outputAction": "BLOCK",
                "inputEnabled": true,
                "outputEnabled": true
            }
        ]
    },
    "contextualGroundingPolicy": {
