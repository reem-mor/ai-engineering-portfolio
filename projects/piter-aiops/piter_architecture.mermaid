flowchart TB
    User["NOC / SRE Engineer"]

    subgraph UI["Presentation — Docker → EC2"]
        Flask["Flask + React SPA"]
        Console["/console Jinja fallback"]
    end

    subgraph RAGtier["RAG tiers (rag_factory)"]
        Agent["Bedrock Agent — invoke_agent"]
        RnG["Bedrock retrieve_and_generate"]
        Local["Local TF-IDF fallback"]
    end

    subgraph KBox["Knowledge Base — RAG"]
        KB[["Bedrock Knowledge Base"]]
        S3[("S3 — runbook documents")]
    end

    subgraph Tools["Bedrock Action Groups (Lambda) — production tools"]
        L1["piter-recent-deployments"]
        L2["piter-service-context"]
        L3["piter-similar-incidents"]
        L4["piter-escalation — preview/mock/gated-live"]
    end

    subgraph MCPlayer["MCP server — read-only local contract layer"]
        MCP["mcp/server.py — same 4 tools"]
    end

    Mem[("Session memory<br/>store · summarize · reuse")]
    Data[("CSV / JSON<br/>deploys · catalog · impact · history")]
    Notify["SNS / SES / WhatsApp<br/>mock by default · gated live"]

    User -->|"submit alert"| Flask
    Console -.->|"parity demo"| Flask
    Flask -->|"InvokeAgent sessionId"| Agent
    Flask -->|"fallback"| RnG
    RnG -->|"fallback"| Local
    Agent --> Mem

    Agent -->|"retrieve cited"| KB
    RnG -->|"retrieve cited"| KB
    Local -->|"retrieve cited"| Data
    S3 -->|"sync"| KB

    Agent -->|"call tools"| L1
    Agent -->|"call tools"| L2
    Agent -->|"call tools"| L3
    Agent -->|"call tools"| L4
    L4 -.->|"gated, confirmed"| Notify

    MCP -.->|"same logic (read-only)"| L1
    MCP -.-> L2
    MCP -.-> L3

    L1 --> Data
    L2 --> Data
    L3 --> Data
    L4 --> Data

    Agent -->|"triage card + citations + tool results"| Flask
    Local -->|"triage card + citations"| Flask

    %% Legacy AWS function names iiq-correlate / iiq-context / iiq-similar map 1:1 to piter-* tools.
