{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SnsEscalationTopicPublish",
      "Effect": "Allow",
      "Action": [
        "sns:Publish"
      ],
      "Resource": "arn:aws:sns:us-east-1:329597159579:piter-aiops-escalation"
    },
    {
      "Sid": "SnsDirectMobilePublish",
      "Effect": "Allow",
      "Action": [
        "sns:Publish"
      ],
      "Resource": "*"
    },
    {
      "Sid": "SmsVoiceV2Send",
      "Effect": "Allow",
      "Action": [
        "sms-voice:SendTextMessage",
        "sms-voice:DescribeAccountAttributes",
        "sms-voice:DescribeOptedOutNumbers",
        "sms-voice:DescribePhoneNumbers"
      ],
      "Resource": "*"
    },
    {
      "Sid": "SnsSmsAccountRead",
      "Effect": "Allow",
      "Action": [
        "sns:GetSMSAttributes",
        "sns:SetSMSAttributes",
        "sns:ListSMSSandboxPhoneNumbers",
        "sns:CreateSMSSandboxPhoneNumber",
        "sns:VerifySMSSandboxPhoneNumber",
        "sns:DeleteSMSSandboxPhoneNumber",
        "sns:CheckIfPhoneNumberIsOptedOut"
      ],
      "Resource": "*"
    },
    {
      "Sid": "SesSendFromVerifiedIdentity",
      "Effect": "Allow",
      "Action": [
        "ses:SendEmail",
        "ses:SendRawEmail"
      ],
      "Resource": [
        "arn:aws:ses:us-east-1:329597159579:identity/sender@example.com",
        "arn:aws:ses:us-east-1:329597159579:identity/oncall@example.com",
        "arn:aws:ses:us-east-1:329597159579:configuration-set/piter-aiops-escalations"
      ]
    },
    {
      "Sid": "SesSendQuotaRead",
      "Effect": "Allow",
      "Action": [
        "ses:GetAccount",
        "ses:GetSendQuota",
        "sesv2:GetAccount",
        "sesv2:GetEmailIdentity",
        "sesv2:ListEmailIdentities"
      ],
      "Resource": "*"
    }
  ]
}
