# PITER AiOps — environment template
# Copy:  cp .env.example .env   (Windows: copy .env.example .env)
# Never commit .env. Fill placeholders; use ~/.aws for credentials (not keys here).
#
# Config loader: app/config.py — PITER_* names preferred; legacy names still work.

# =============================================================================
# Preferred PITER_ variables (single source of truth)
# =============================================================================

PITER_AWS_REGION=us-east-1

# Bedrock Knowledge Base (required when PITER_USE_BEDROCK=true)
PITER_BEDROCK_KB_ID=
PITER_BEDROCK_DATA_SOURCE_ID=
# Prefer Claude Sonnet 4.5 for agent quality; Haiku 4.5 for lower latency/cost
PITER_BEDROCK_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-sonnet-4-20250514-v1:0
PITER_BEDROCK_NUM_RESULTS=5

# Bedrock Agent (required when RAG_BACKEND=agent)
PITER_BEDROCK_AGENT_ID=
PITER_BEDROCK_AGENT_ALIAS_ID=

# S3 corpus upload (optional; for document upload + KB sync scripts)
PITER_S3_BUCKET=
PITER_S3_PREFIX=projects/piter-aiops/data/sample_documents

# Flask
PITER_FLASK_SECRET_KEY=change-me-in-production
# Generate: python -c "import secrets; print(secrets.token_hex(32))"

PITER_USE_BEDROCK=false
PITER_MOCK_MODE=false
PITER_MEMORY_ENABLED=true

# =============================================================================
# RAG backend & runtime (unprefixed names — read directly by config.py)
# =============================================================================

# agent                  -> boto3 invoke_agent through Bedrock Agent Runtime
# retrieve_and_generate  -> direct KB API fallback when an agent is not provisioned
RAG_BACKEND=agent

# development | production
FLASK_ENV=development

# Max upload size in bytes (5 MiB default)
MAX_UPLOAD_BYTES=5242880

# Legacy UI (Jinja) instead of committed SPA build
FORCE_LEGACY_UI=false

# Vite dev server origin for CORS when FLASK_ENV=development
FRONTEND_DEV_ORIGIN=http://localhost:5173

# Bedrock short-term API key (boto3 >= 1.39). Generate in Bedrock console → API keys.
# Local Python: set Windows user env AWS_BEARER_TOKEN_BEDROCK, or paste here (never commit).
# Comment out AWS_PROFILE when using bearer-only for invoke_agent / retrieve.
AWS_BEARER_TOKEN_BEDROCK=

# AWS CLI profile for SNS/SES/S3 and setup scripts (keys live in ~/.aws/credentials, not here)
AWS_PROFILE=

# =============================================================================
# Legacy fallbacks (optional if PITER_* vars above are set)
# =============================================================================
# AWS_REGION=
# BEDROCK_KB_ID=
# BEDROCK_MODEL_ARN=
# BEDROCK_NUM_RESULTS=5
# BEDROCK_AGENT_ID=
# BEDROCK_AGENT_ALIAS_ID=
# BEDROCK_DATA_SOURCE_ID=
# USE_BEDROCK=true
# MOCK_MODE=false
# MEMORY_ENABLED=true
# S3_BUCKET=
# S3_PREFIX=
# FLASK_SECRET_KEY=

# =============================================================================
# Notification safety (mock by default — no live SNS/SES without explicit gates)
# =============================================================================

PITER_NOTIFICATION_MODE=mock
PITER_ENABLE_LIVE_DISPATCH=false
PITER_NOTIFICATION_REQUIRE_CONFIRMATION=true
PITER_NOTIFICATION_CONFIRMATION_TOKEN=
PITER_NOTIFICATION_ALLOWLIST=
PITER_NOTIFICATION_ALLOWED_SEVERITIES=P1,P2
PITER_DEMO_SMS_RECIPIENT=
PITER_DEMO_WHATSAPP_RECIPIENT=
PITER_DEMO_EMAIL_RECIPIENT=
# WhatsApp (CallMeBot — personal demo; no AWS SMS required)
PITER_WHATSAPP_PROVIDER=callmebot
PITER_WHATSAPP_API_KEY=
# Meta Cloud API alternative:
# PITER_WHATSAPP_PROVIDER=cloud
# PITER_WHATSAPP_ACCESS_TOKEN=
# PITER_WHATSAPP_PHONE_NUMBER_ID=
PITER_SNS_TOPIC_ARN=
PITER_SNS_SMS_USE_TOPIC=false
PITER_SMS_USE_VOICE_V2=true
PITER_SES_SENDER_EMAIL=
PITER_SES_CONFIGURATION_SET=
PITER_SES_REPLY_TO=
PITER_NOTIFICATION_MAX_SENDS_PER_INCIDENT=1

# Redirect /console to SPA storm page only after verify_spa_demo.py passes
PITER_CONSOLE_REDIRECT_SPA=false

# =============================================================================
# Live demo note
# =============================================================================
# Final demo should use RAG_BACKEND=agent when agent_smoke_test.py passes.
# Use RAG_BACKEND=retrieve_and_generate only as a direct-KB fallback.
# Offline rehearsal: PITER_USE_BEDROCK=false (docker compose default).
