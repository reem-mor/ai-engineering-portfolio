# --- Run mode ---
# Local-first by default: the app runs a reliable OFFLINE demo (local TF-IDF RAG
# over knowledge_base/runbooks/ + deterministic tools) with NO AWS required.
# Set USE_BEDROCK=true to use the managed Bedrock Agent / Knowledge Base instead.
# When USE_BEDROCK is unset and AWS config is incomplete, the app auto-falls back
# to local mode so the live demo never fails.
USE_BEDROCK=false

# --- AWS (only needed when USE_BEDROCK=true) ---
# Credentials: aws configure → ~/.aws/credentials (NEVER put ACCESS_KEY/SECRET here).
# Region where your Knowledge Base lives (must match KB region).
AWS_REGION=us-east-1

# Profile name from ~/.aws/config (e.g. default or your named profile).
AWS_PROFILE=default

# The Knowledge Base ID copied from the Bedrock console.
BEDROCK_KB_ID=XXXXXXXXXX

# Inference-profile ARN used for answer generation.
# Best practice: use a CURRENT model via a cross-region inference profile (not a legacy
# foundation-model ARN). Default below is Claude Haiku 4.5 — swap <account-id> for yours.
# Alternative: arn:aws:bedrock:us-east-1:<account-id>:inference-profile/us.amazon.nova-lite-v1:0
# (Legacy anthropic.claude-3-haiku-20240307 foundation-model IDs are older and may be blocked.)
BEDROCK_MODEL_ARN=arn:aws:bedrock:us-east-1:<account-id>:inference-profile/us.anthropic.claude-haiku-4-5-20251001-v1:0

# How many chunks the KB retrieves per query (3-10 is sane).
BEDROCK_NUM_RESULTS=5

# --- Bedrock Agent (primary backend) ---
# Create via scripts/setup_bedrock_agent.py or docs/bedrock_agent_setup.md
BEDROCK_AGENT_ID=XXXXXXXXXX
BEDROCK_AGENT_ALIAS_ID=YYYYYYYYYY
# agent = invoke_agent (default) | retrieve_and_generate = direct KB API
RAG_BACKEND=agent

# --- Action group (setup_action_group.py) ---
LAMBDA_FUNCTION_NAME=incidentiq-actions
ACTION_GROUP_NAME=incidentiq-ops
ACTION_GROUP_OPENAPI_S3_KEY=agent/incidentiq-ops/openapi_schema.yaml
BEDROCK_AGENT_RESOURCE_ROLE_NAME=incidentiq-agent-role
LAMBDA_EXECUTION_ROLE_NAME=incidentiq-lambda-role

# --- Enrichment Lambdas (setup_enrichment_lambdas.py) ---
# iiq-correlate, iiq-context, iiq-similar — action groups on same agent

# --- AgentCore Gateway MCP (optional Path A) ---
# AGENTCORE_GATEWAY_URL=
# COGNITO_DOMAIN=

# --- S3 corpus (document upload) ---
S3_BUCKET=reem-amdocs-ai-artifacts-3331
S3_PREFIX=projects/incidentIQ-midproject/data/sample_documents
# Data source ID from Bedrock console (for optional sync after web upload)
BEDROCK_DATA_SOURCE_ID=YICXAB6WOG
MAX_UPLOAD_BYTES=5242880

# --- Flask ---
# Long random string. Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace-me-with-a-long-random-hex-string

# Set to "production" on EC2, "development" locally.
FLASK_ENV=development

# Container listens on 8080 (gunicorn in Dockerfile). Course handouts sometimes
# mention port 5000 — map locally with `5000:8080` in docker compose if needed.
# PORT=8080

# AWS credentials: ~/.aws/credentials + ~/.aws/config only (never ACCESS_KEY/SECRET in .env).
# AWS_PROFILE selects which profile Docker/boto3 uses from the mounted ~/.aws volume.
# On EC2 use IAM instance profile instead of keys.
