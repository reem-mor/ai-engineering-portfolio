# --- AWS Bedrock ---
# Region where your Knowledge Base lives (must match KB region).
AWS_REGION=us-east-1

# The Knowledge Base ID copied from the Bedrock console.
BEDROCK_KB_ID=XXXXXXXXXX

# Inference-profile ARN used for answer generation.
# Best practice: use a CURRENT model via a cross-region inference profile (not a legacy
# foundation-model ARN). Default below is Claude Haiku 4.5 — swap <account-id> for yours.
# Alternative: arn:aws:bedrock:us-east-1:<account-id>:inference-profile/us.amazon.nova-lite-v1:0
# (Legacy anthropic.claude-3-haiku-20240307 foundation-model IDs are older and may be blocked.)
BEDROCK_MODEL_ARN=arn:aws:bedrock:us-east-1:<account-id>:inference-profile/us.anthropic.claude-haiku-4-5-20251001-v1:0

# How many chunks the KB retrieves per query (3-10 is sane).
BEDROCK_NUM_RESULTS=5

# --- S3 corpus (document upload) ---
S3_BUCKET=reem-amdocs-ai-artifacts-3331
S3_PREFIX=projects/incident-rag-bedrock/data/sample_documents
# Data source ID from Bedrock console (for optional sync after web upload)
BEDROCK_DATA_SOURCE_ID=YICXAB6WOG
MAX_UPLOAD_BYTES=5242880

# --- Flask ---
# Long random string. Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace-me-with-a-long-random-hex-string

# Set to "production" on EC2, "development" locally.
FLASK_ENV=development

# Container listens on 8080 (gunicorn in Dockerfile). Course handouts sometimes
# mention port 5000 — map locally with `5000:8080` in docker compose if needed.
# PORT=8080

# Local AWS auth: use `aws configure` or set AWS_PROFILE in your shell (not in .env).
# On EC2 we rely on the IAM instance profile.
# Locally, use `aws configure` or AWS_PROFILE.
