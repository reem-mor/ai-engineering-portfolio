# Copy to .env and fill in your real values. NEVER commit .env.
# .env is gitignored; only this sanitized example file is committed.

# OpenAI — RAG homework and capstone (capstone also uses backend/.env)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Google AI — lecture 06 Flask RAG demo, lecture 08 MCP Gemini demo
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face — lecture NLP demos
HF_TOKEN=your_huggingface_token_here

# Flask
FLASK_ENV=development

# Lovable MCP (.cursor/mcp.json) — static OAuth client id
LOVABLE_CLIENT_ID=your_lovable_client_id_here

# n8n MCP servers (.cursor/mcp.json) — cloud instance URL + API key
N8N_API_URL=https://your-instance.app.n8n.cloud
N8N_API_KEY=your_n8n_api_key_here

# AWS MCP servers (.cursor/mcp.json) — use a named profile, never raw keys
AWS_PROFILE=your_aws_profile_name
AWS_REGION=us-east-1
