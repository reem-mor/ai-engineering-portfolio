# Copy to .env in the repo root. NEVER commit .env — it is gitignored.
# Only this sanitized template is tracked. See docs/AGENT-TOOLING.md for MCP wiring.

# =============================================================================
# LLM providers (homework, capstone, lectures)
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

ANTHROPIC_API_KEY=your_anthropic_api_key_here

GEMINI_API_KEY=your_gemini_api_key_here

HF_TOKEN=your_huggingface_token_here

# Lecture 11 — local Qwen3.6 via llama-cpp-python (see lectures/11_local_models_webui/)
QWEN36_REPO=unsloth/Qwen3.6-27B-MTP-GGUF
QWEN36_QUANT=*UD-Q4_K_XL*
QWEN36_MMPROJ=mmproj-F16.gguf
QWEN36_N_CTX=8192
QWEN36_N_GPU_LAYERS=35
QWEN_N_GPU_LAYERS=999
LLAMA_SERVER_PORT=8080

# =============================================================================
# Flask / local dev
# =============================================================================
FLASK_ENV=development

# =============================================================================
# Homework 07 — Open WebUI CVE assistant (RapidAPI + KB upload)
# =============================================================================
RAPIDAPI_KEY=
RAPIDAPI_HOST=
OWUI_URL=http://localhost:3000
OWUI_API_KEY=
TOOLS_SERVER_PORT=5005

# =============================================================================
# MCP — Lovable (OAuth client id; not a secret but keep out of git)
# =============================================================================
LOVABLE_CLIENT_ID=your_lovable_client_id_here

# =============================================================================
# MCP — n8n (cloud instance; used by n8n-workflows server in .mcp.json)
# =============================================================================
N8N_API_URL=https://your-instance.app.n8n.cloud
N8N_API_KEY=your_n8n_api_key_here

# =============================================================================
# MCP / AWS — prefer named profile; never commit access keys
# =============================================================================
AWS_PROFILE=your_aws_profile_name
AWS_REGION=us-east-1

# Optional Bedrock KB retrieval MCP (when using bedrock-kb server)
# BEDROCK_KB_ID=your_kb_id_here

# =============================================================================
# MCP — Kaggle (hw07 dataset download)
# https://www.kaggle.com/settings → Create New Token
# =============================================================================
KAGGLE_API_TOKEN=your_kaggle_api_token_here
