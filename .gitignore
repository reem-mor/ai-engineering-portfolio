# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
.venv312/
venv/
env/

# Distribution / packaging
*.egg-info/
.eggs/
dist/
build/
*.tsbuildinfo
.cache/

# Node.js / frontend
node_modules/
*.egg

# Environment variables and secrets — never commit real values
.env
.env.*
!.env.example
*.env.local
*.env.production
*.env.development

# Credential files (Kaggle CLI, GCP, OAuth exports, etc.)
kaggle.json
**/kaggle.json
credentials.json
**/credentials.json
secrets.json
**/secrets.json
*.credentials
auth.json
**/auth.json
**/token.json
service-account*.json
client_secret*.json
google-credentials.json
.netrc
.npmrc

# Cloud / TLS key material
.aws/
*.pem
*.key
*.p12
*.pfx
*.jks

# Project-generated RAG indexes and local artifacts
knowledge_base/faiss_index/
projects/*/knowledge_base/faiss_index/
*.faiss
*.pkl
*.sqlite
*.sqlite3
*.db

# Jupyter
.ipynb_checkpoints/

# Logs
*.log
*.err.log

# OS artifacts
.DS_Store
Thumbs.db

# Firecrawl CLI cache
.firecrawl/

# Duplicate agent skill mirror (canonical library: .cursor/skills/)
.agents/

# Root-level local data stores (Chroma, etc.) — project data lives in */data/ subfolders
/data/

# Extracted flagship — full tree must not reappear under projects/
projects/piter-aiops/

# Playwright MCP session snapshots (generated browser a11y dumps)
.playwright-mcp/

# IDE/editor local state
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.claude/
*.swp

# Cursor: rules + skills committed; local MCP overrides stay ignored
.cursor/mcp.json
.cursor/plans/
!.cursor/mcp.json.example

# Agent / IDE local overrides
.mcp.json.local
*.local.json

# Incident Assistant RAG - generated data
projects/incident-assistant-rag/data/raw/*
projects/incident-assistant-rag/data/processed/*
projects/incident-assistant-rag/data/chunks/*
projects/incident-assistant-rag/data/faiss_index/*

!projects/incident-assistant-rag/data/raw/.gitkeep
!projects/incident-assistant-rag/data/processed/.gitkeep
!projects/incident-assistant-rag/data/chunks/.gitkeep
!projects/incident-assistant-rag/data/faiss_index/.gitkeep

# ML training artifacts (CatBoost, etc.)
catboost_info/

# Frontend SPA build output (source lives in */frontend/; rebuild with npm run build)
**/app/static/spa/assets/
**/app/static/spa/index.html

# Large local archives
*.tar
*.tar.gz
*.zip
projects/piter-aiops/*.tar
flagships/**/var/
