# Oz VeRuach Course Assistant — environment template.
# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).
# Only this sanitized example file is committed. Secrets are read at runtime only.

# ---------------------------------------------------------------------------
# Core runtime
# ---------------------------------------------------------------------------
ENVIRONMENT=development            # development | production | test
LOG_LEVEL=INFO
LOG_JSON=true
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080                   # worker uses HEALTH_PORT+1

# ---------------------------------------------------------------------------
# Telegram (Phase 0)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_botfather_token_here
# Two-tier roles (comma-separated numeric IDs). Owners are implicitly admins.
# Collect IDs with the built-in /myid command: each person messages the bot once.
OWNER_TELEGRAM_IDS=                # Re'em (operator / superadmin)
ADMIN_TELEGRAM_IDS=                # Alex + Sagy
RUN_MODE=polling                   # polling (dev) | webhook (prod)
WEBHOOK_URL=
WEBHOOK_LISTEN_HOST=0.0.0.0
WEBHOOK_LISTEN_PORT=8443

# ---------------------------------------------------------------------------
# Google Drive + Gmail (Phase 2 / Phase 4) — leave blank until those phases.
# v1 decision: OAuth with Re'em's own Google account (already has full view access),
# set the OAuth app to Internal / In-production so the refresh token does not expire.
# Optional later upgrade: a Service Account (GOOGLE_SA_JSON); then the root-folder
# owner (Sagy) shares the course folder with the SA email as Viewer.
# ---------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=            # v1 default: OAuth (Re'em's account)
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=        # stored offline refresh token
GOOGLE_SA_JSON=                    # optional upgrade: path to service-account JSON
GOOGLE_API_KEY=                    # optional: Gemini
COURSE_DRIVE_FOLDER_ID=1GfQBI1btQSoyMLQ7z-_aE4xBnObsO2wO
# The only Drive write path (admin upload filing). Off by default; needs a write scope.
DRIVE_WRITE_ENABLED=false

# --- Notifications / worker -------------------------------------------------
BROADCAST_RATE_PER_SEC=25
DRIVE_POLL_MINUTES=15

# ---------------------------------------------------------------------------
# Homework email routing (Phase 4) — addresses supplied via env, never in code.
# CC supports a comma-separated list (Sagy has two addresses).
# ---------------------------------------------------------------------------
HW_TO_EMAIL=                       # Alex, e.g. kalex7878@gmail.com
HW_CC_EMAIL=                       # Sagy, e.g. sagy.galor@fursa.org.il,sagy.galor@portlandtrust.org.il
SMTP_HOST=                         # SMTP fallback (e.g. smtp.gmail.com)
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=                         # Google App Password if using SMTP

# ---------------------------------------------------------------------------
# LLM providers (Phase 3) — at least one required then; OpenAI also powers
# ASR + embeddings. Missing providers fall back gracefully.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model registry overrides (optional) — "provider:model", provider in
# {anthropic, openai, google}. Defaults (Section 7) are baked in; set these only to
# re-point a role. Missing-provider roles fall back to an available provider.
MODEL_ROUTER=
MODEL_CONVERSATIONAL=
MODEL_SUMMARIZER=
MODEL_EMAIL_WRITER=
MODEL_RECOMMENDATIONS=
ASR_MODEL=gpt-4o-mini-transcribe

# --- RAG / recommendations (Phase 6) ----------------------------------------
EMBEDDINGS_MODEL=text-embedding-3-small
WEB_SEARCH_ENABLED=false
RAG_TOP_K=4

# ---------------------------------------------------------------------------
# Datastore / vector store (Phase 2+ / Phase 6)
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/oz_veruach.db
SUPABASE_DB_URL=                   # Postgres+pgvector for production
