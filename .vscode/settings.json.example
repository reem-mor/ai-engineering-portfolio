{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "python.terminal.activateEnvironment": true,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": false,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit"
    }
  },
  "ruff.lint.args": [],
  "files.eol": "\n",
  "files.encoding": "utf8",
  "files.exclude": {
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.mypy_cache": true,
    "**/__pycache__": true,
    "**/catboost_info": true,
    "**/.firecrawl": true,
    "**/.playwright-mcp": true,
    "**/.agents": true,
    "data": true,
    "projects/piter-aiops": true
  },
  "search.exclude": {
    "**/.venv": true,
    "**/node_modules": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "projects/piter-aiops": true
  }
}
