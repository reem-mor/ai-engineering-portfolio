{
  "_comment": "Copy to .cursor/mcp.json. rapidapi uses stdio mcp-remote (not HTTP) — see scripts/verify-rapidapi-mcp.py",
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "timeout": 120000
    },
    "kaggle": {
      "type": "http",
      "url": "https://www.kaggle.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:KAGGLE_API_TOKEN}"
      }
    },
    "openwebui": {
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["${workspaceFolder}/scripts/run-mcp-openwebui.py"],
      "timeout": 180000,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    "rapidapi": {
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["${workspaceFolder}/scripts/run-mcp-rapidapi.py"],
      "timeout": 180000,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    "course-tools": {
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["${workspaceFolder}/scripts/run-mcp-course-tools.py"],
      "timeout": 60000,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}
