{
  "mcpServers": {
    "lovable": {
      "type": "http",
      "url": "https://mcp.lovable.dev",
      "auth": {
        "CLIENT_ID": "${env:LOVABLE_CLIENT_ID}"
      }
    },
    "n8n-workflows": {
      "command": "npx",
      "args": [
        "-y",
        "n8n-mcp"
      ],
      "envFile": "${workspaceFolder}/.env",
      "timeout": 120000,
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true"
      }
    },
    "aws-api": {
      "command": "uvx",
      "args": [
        "awslabs.aws-api-mcp-server@latest"
      ],
      "envFile": "${workspaceFolder}/.env",
      "timeout": 120000,
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "bedrock-kb": {
      "command": "uvx",
      "args": [
        "awslabs.bedrock-kb-retrieval-mcp-server@latest"
      ],
      "envFile": "${workspaceFolder}/.env",
      "timeout": 120000,
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "BEDROCK_KB_RERANKING_ENABLED": "false"
      }
    },
    "aws-knowledge": {
      "type": "http",
      "url": "https://knowledge-mcp.global.api.aws"
    },
    "kaggle": {
      "type": "http",
      "url": "https://www.kaggle.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:KAGGLE_API_TOKEN}"
      }
    },
    "course-tools": {
      "command": "${workspaceFolder}/lectures/08_mcp/.venv/Scripts/python.exe",
      "args": [
        "${workspaceFolder}/lectures/08_mcp/server/tools_server.py"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}