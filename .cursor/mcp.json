{
  "mcpServers": {
    "lovable": {
      "type": "http",
      "url": "https://mcp.lovable.dev",
      "auth": {
        "CLIENT_ID": "${env:LOVABLE_CLIENT_ID}"
      }
    },

    "n8n-workflows": {
      "command": "npx",
      "args": ["-y", "n8n-mcp"],
      "envFile": "${workspaceFolder}/.env",
      "timeout": 120000,
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_API_URL": "https://reemmor.app.n8n.cloud",
        "N8N_API_KEY": "${env:N8N_API_KEY}"
      }
    },

    "aws-api": {
      "command": "uvx",
      "args": ["awslabs.aws-api-mcp-server@latest"],
      "timeout": 120000,
      "env": {
        "AWS_PROFILE": "reemmor",
        "AWS_REGION": "us-east-1",
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },

    "bedrock-kb": {
      "command": "uvx",
      "args": ["awslabs.bedrock-kb-retrieval-mcp-server@latest"],
      "timeout": 120000,
      "env": {
        "AWS_PROFILE": "reemmor",
        "AWS_REGION": "us-east-1",
        "FASTMCP_LOG_LEVEL": "ERROR",
        "BEDROCK_KB_RERANKING_ENABLED": "false"
      }
    },

    "aws-knowledge": {
      "type": "http",
      "url": "https://knowledge-mcp.global.api.aws"
    },

    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "timeout": 120000
    },

    "course-tools": {
      "command": "${workspaceFolder}/lectures/08_mcp/.venv/Scripts/python.exe",
      "args": ["${workspaceFolder}/lectures/08_mcp/server/tools_server.py"],
      "timeout": 120000,
      "env": {
        "PYTHONUNBUFFERED": "1",
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    }
  }
}