{
  "_comment": "Cursor loads THIS file. Reload after edits. HTTP rapidapi needs RAPIDAPI_* in Windows user env — run: python scripts/sync_mcp_env_to_user.py",
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "timeout": 120000
    },
    "kaggle": {
      "type": "http",
      "url": "https://www.kaggle.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:KAGGLE_API_TOKEN}"
      }
    },
    "openwebui": {
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["${workspaceFolder}/scripts/run-mcp-openwebui.py"],
      "timeout": 120000,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    "rapidapi": {
      "type": "http",
      "url": "https://mcp.rapidapi.com",
      "headers": {
        "x-api-host": "${env:RAPIDAPI_HOST}",
        "x-api-key": "${env:RAPIDAPI_KEY}"
      }
    },
    "course-tools": {
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["${workspaceFolder}/scripts/run-mcp-course-tools.py"],
      "timeout": 60000,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}
