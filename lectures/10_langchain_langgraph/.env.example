# Required for LangChain / LangGraph demos (03_rag_qa and later).
# ML demos and exercises run offline and do not need this key.
OPENAI_API_KEY=sk-your-key-here

# Default model for demos (cost-effective)
OPENAI_MODEL=gpt-4o-mini

# Optional: LangSmith tracing during live demos
# LANGCHAIN_API_KEY=lsv2-your-key-here
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=lecture10-langgraph
