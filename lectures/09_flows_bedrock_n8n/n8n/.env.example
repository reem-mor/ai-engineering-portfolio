# n8n Docker configuration - copy to .env and fill in values.
# .env is gitignored; never commit real secrets.

# Pinned n8n image tag (https://docs.n8n.io/release-notes/). >=1.88 required for native MCP nodes.
N8N_IMAGE_TAG=2.25.6

# Host port n8n is published on (localhost only).
N8N_PORT=5678

# Timezone for schedules/cron and container clock.
TZ=Asia/Jerusalem

# Public base URL used when registering webhooks.
WEBHOOK_URL=http://localhost:5678/

# REQUIRED - encrypts stored credentials. Generate once and never change it:
#   PowerShell: $b=[byte[]]::new(32); [Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($b); -join ($b | % { $_.ToString('x2') })
#   Linux/mac:  openssl rand -hex 32
# Losing/changing this key makes all saved credentials unreadable.
N8N_ENCRYPTION_KEY=
