          "name": "Pinecone account"
        }
      },
      "onError": "continueErrorOutput",
      "notes": "MANUAL BIND REQUIRED: attach a Pinecone (pineconeApi) credential. Lists indexes to confirm Pinecone connectivity + that 'company-kb' exists."
    },
    {
      "parameters": {
        "resource": "fileFolder",
        "searchMethod": "query",
        "queryString": "trashed=false",
        "limit": 1,
        "filter": {
          "folderId": {
            "__rl": true,
            "mode": "id",
            "value": "17Rg2teqPNlGUxrWOBM_LxjWeSSvIFKeG",
            "cachedResultName": "KB Folder"
          }
        },
        "options": {}
      },
