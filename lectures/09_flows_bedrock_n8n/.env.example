# AWS credentials — use AWS CLI profile or IAM role; never commit real keys.
AWS_REGION=us-east-1
AWS_PROFILE=default

# Bedrock Flows (set after running create_flow.py or from the console)
BEDROCK_FLOW_ID=
BEDROCK_FLOW_ALIAS_ID=

# IAM role ARN that Bedrock Flows uses at runtime (required for create_flow.py)
BEDROCK_FLOWS_EXECUTION_ROLE_ARN=arn:aws:iam::123456789012:role/BedrockFlowsExecutionRole

# Bedrock model for the inline prompt node (enable in console first)
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
