{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "FlowsTrustBedrock",
      "Effect": "Allow",
      "Principal": {
        "Service": "bedrock.amazonaws.com"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "329597159579"
        },
        "ArnLike": {
          "AWS:SourceArn": "arn:aws:bedrock:us-east-1:329597159579:flow/*"
        }
      }
    }
  ]
}
