{
  "_comment": "Minimal MCP set for lecture 08 — full catalog in repo root .mcp.json",
  "_setup": "Run scripts/setup-dev.ps1 from repo root, then use root .mcp.json in Cursor",
  "mcpServers": {
    "course-tools": {
      "command": "python",
      "args": ["${workspaceFolder}/scripts/run-mcp-course-tools.py"],
      "timeout": 60000,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "timeout": 120000
    },
    "kaggle": {
      "type": "http",
      "url": "https://www.kaggle.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:KAGGLE_API_TOKEN}"
      }
    }
  }
}
