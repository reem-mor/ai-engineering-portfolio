# ============================================================================
# OzVaRoah AI Agent Course Bot — environment configuration
# Copy to `.env` and fill in. NEVER commit a real .env. All secrets live here,
# nothing is hardcoded. Variables are grouped by the phase that introduces them.
# ============================================================================

# --- Core / LLM (Phase 1 & 4) -----------------------------------------------
# Which provider the agent uses. One of: anthropic | openai
LLM_PROVIDER=anthropic
# Default chat model (configurable). Latest Claude Sonnet by default.
LLM_MODEL=claude-sonnet-4-6
# Provide the key matching LLM_PROVIDER. At least one is required to run the agent.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Telegram interface (Phase 5) -------------------------------------------
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user IDs with admin rights (optional).
ADMIN_TELEGRAM_IDS=

# --- Google Drive (Phase 2) -------------------------------------------------
# Read-only access to the course Drive folder. OAuth (user account) by default.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# The Drive folder ID that holds the course materials (lectures, recordings, HW).
# Defaults to the real Oz VeRuach Cohort-1 folder; override only if it changes.
DRIVE_ROOT_FOLDER_ID=1GfQBI1btQSoyMLQ7z-_aE4xBnObsO2wO

# --- RAG / vector store (Phase 3) -------------------------------------------
# Backend for the vector store. One of: chroma | pinecone
VECTOR_STORE=chroma
# Local Chroma persistence directory (used when VECTOR_STORE=chroma).
CHROMA_DIR=./data/chroma
# Embedding model (OpenAI by default; requires OPENAI_API_KEY).
EMBEDDING_MODEL=text-embedding-3-small
# Pinecone (only when VECTOR_STORE=pinecone — swappable upgrade path).
PINECONE_API_KEY=
PINECONE_INDEX=

# --- Homework submission (Phase 4) ------------------------------------------
# Recipients for homework emails. To = Alex; CC = Sagy. Never hardcoded.
# HW_CC_EMAIL may be comma-separated to CC several addresses.
HW_TO_EMAIL=
HW_CC_EMAIL=
# Greeting name used in the email body ("Hello Alex,").
HW_TO_NAME=Alex
# Gmail send uses the same Google OAuth credentials above (gmail.send scope).

# --- Misc -------------------------------------------------------------------
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
