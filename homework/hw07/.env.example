# Optional local overrides only — secrets belong in repo root .env (never commit .env)
# Primary config: C:\dev\ai-engineering-portfolio\.env

# --- RapidAPI: primary live CVE source (optional) ---------------------------
# Subscribe to a CVE API on RapidAPI. Use RAPIDAPI_CVE_HOST for the CVE product.
# RAPIDAPI_HOST may point at JSearch/MCP — that is NOT used by the CVE tool server.
# Leave blank to use free Shodan CVEDB fallback.
RAPIDAPI_KEY=
RAPIDAPI_HOST=
RAPIDAPI_CVE_HOST=

# --- Open WebUI -------------------------------------------------------------
OWUI_URL=http://localhost:3000
OWUI_EMAIL=
OWUI_PASSWORD=
OWUI_API_KEY=
# Auto-written by scripts/bootstrap_owui.py after KB upload:
HW07_KB_ID=

# --- Tool server -------------------------------------------------------------
TOOLS_SERVER_PORT=5005
TOOLS_HTTP_TIMEOUT=15
