# hw07 local overrides — OPTIONAL and non-secret only.
# The CANONICAL config/secrets file is the repo root .env (../../.env):
# all hw07 scripts load the root .env first; this file only fills gaps.
# Never commit .env — both are gitignored.

# --- Tool server (non-secret defaults) ---------------------------------------
TOOLS_SERVER_PORT=5005
TOOLS_HTTP_TIMEOUT=15

# --- Open WebUI (non-secret defaults) ----------------------------------------
OWUI_URL=http://localhost:3000

# Secrets live ONLY in the repo root .env:
#   RAPIDAPI_KEY, RAPIDAPI_JOBS_HOST, RAPIDAPI_JOBS_BASE_URL
#   KAGGLE_API_TOKEN
#   OWUI_EMAIL, OWUI_PASSWORD (or OWUI_API_KEY)
#   OWUI_KNOWLEDGE_ID, OWUI_FILE_ID (written by owui_kb_setup.py --write-env)
