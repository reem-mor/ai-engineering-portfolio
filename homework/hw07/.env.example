# Copy to .env — never commit .env
# Shared keys (KAGGLE_API_TOKEN) may also live in repo root .env

# --- RapidAPI: primary live CVE source (optional) ---------------------------
# Subscribe to a CVE API on RapidAPI, paste key + host. Adjust path in tools_server.py if needed.
# Leave blank to use free Shodan CVEDB fallback.
RAPIDAPI_KEY=
RAPIDAPI_HOST=

# --- Open WebUI: owui_kb_setup.py -------------------------------------------
OWUI_URL=http://localhost:3000
OWUI_API_KEY=

# --- Tool server -------------------------------------------------------------
TOOLS_SERVER_PORT=5005
TOOLS_HTTP_TIMEOUT=15
