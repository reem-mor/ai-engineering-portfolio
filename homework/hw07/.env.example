# Copy to .env — never commit .env
RAPIDAPI_KEY=your_rapidapi_key_here
# API host only — NOT rapidapi.com (use the JSearch app host)
RAPIDAPI_HOST=jsearch.p.rapidapi.com
# Derived by jsearch_client: https://{RAPIDAPI_HOST}/search (documentation only)
RAPIDAPI_BASE_URL=https://jsearch.p.rapidapi.com
# Default port for tools_server.py (uvicorn)
TOOLS_SERVER_PORT=5005
# Set to 1 for offline pytest/screenshots without RapidAPI quota
HW07_MOCK_RAPIDAPI=0
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key
# Optional — Open WebUI API auth (Settings > Account > API key, or your signup email/password)
# OPEN_WEBUI_API_KEY=sk-...
# OPEN_WEBUI_EMAIL=admin@localhost.com
# OPEN_WEBUI_PASSWORD=admin
